---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Real research posts only, newest-first. The Machines/Challenges links live in
// the top nav, so we don't repeat the external-link stubs here.
const posts = (await getCollection('posts', ({ data }) => !data.draft && !data.externalLink))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const hrefFor = (p: (typeof posts)[number]) => p.data.externalLink ?? `/posts/${p.id}/`;
---

<BaseLayout title="posts" description="Research, notes, and section links.">
  <h1 class="section">Posts</h1>
  <ul class="post-list">
    {posts.map((p) => (
      <li>
        <a href={hrefFor(p)}>
          <span class="post-title">{p.data.title}{p.data.externalLink && <span class="ext"> →</span>}</span>
          {!p.data.externalLink && (
            <time class="post-date" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
          )}
          {p.data.tags.length > 0 && (
            <div class="tags">{p.data.tags.map((t) => <span class="tag">{t}</span>)}</div>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
