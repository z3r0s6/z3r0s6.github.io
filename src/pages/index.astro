---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, ABOUT, SOCIALS } from '../config';

const machines = await getCollection('machines', ({ data }) => !data.draft);
const challenges = await getCollection('challenges', ({ data }) => !data.draft);
---

<BaseLayout>
  <section class="intro">
    <div class="intro-head">
      <img class="avatar" src={SITE.avatar} alt={SITE.author} width="88" height="88" />
      <div>
        <h1>{SITE.title}<span class="cursor">_</span></h1>
        <p class="tagline">{SITE.description}</p>
      </div>
    </div>
  </section>

  <h2 class="section">About Me</h2>
  <p>{ABOUT}</p>

  <h2 class="section">Sections</h2>
  <ul class="socials sections">
    <li><span class="label">Machines</span><a href="/machines">{machines.length} HTB machine writeups →</a></li>
    <li><span class="label">Challenges</span><a href="/challenges">{challenges.length} CTF challenge writeups →</a></li>
    <li><span class="label">Posts</span><a href="/posts">Research →</a></li>
  </ul>

  <h2 class="section">Where to Find Me</h2>
  <ul class="socials">
    {SOCIALS.map((s) => (
      <li>
        <span class="label">{s.label}</span>
        <a href={s.href} rel="me noopener" target="_blank">{s.handle ?? s.href}</a>
      </li>
    ))}
  </ul>
</BaseLayout>
