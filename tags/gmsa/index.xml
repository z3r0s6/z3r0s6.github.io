 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;IP&lt;/td&gt;
 &lt;td&gt;10.129.X.X&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Domain&lt;/td&gt;
 &lt;td&gt;logging.htb&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;DC&lt;/td&gt;
